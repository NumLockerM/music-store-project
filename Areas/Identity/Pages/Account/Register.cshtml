@page
@model Microsoft.AspNetCore.Identity.UI.V5.Pages.Account.Internal.RegisterModel
@{ ViewData["Title"] = "Регистрация"; }

<div class="container mt-3">
    <a href="/" class="text-decoration-none text-dark fw-bold fs-4">🎸 SOUNDWAVE</a>
    <hr>
</div>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0 p-4">
            <h2 class="text-center mb-4">Создать аккаунт</h2>
            <form id="registerForm" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Пароль</label>
                    <input asp-for="Input.Password" type="password" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Повторите пароль</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-success w-100 fw-bold">ЗАРЕГИСТРИРОВАТЬСЯ</button>
                
                <div class="mt-3 text-center small">
                    <a asp-area="Identity" asp-page="/Account/Login">Уже есть аккаунт? Войти</a>
                </div>
            </form>
        </div>
    </div>
</div>