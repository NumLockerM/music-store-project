@page
@model Microsoft.AspNetCore.Identity.UI.V5.Pages.Account.Internal.LoginModel
@{ ViewData["Title"] = "Вход"; }

<div class="container mt-3">
    <a href="/" class="text-decoration-none text-dark fw-bold fs-4">🎸 SOUNDWAVE</a>
    <hr>
</div>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0 p-4">
            <h2 class="text-center mb-4">Вход</h2>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Пароль</label>
                    <input asp-for="Input.Password" type="password" class="form-control" /> <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" type="checkbox" /> <label class="form-check-label small" asp-for="Input.RememberMe">Запомнить меня</label>
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold">ВОЙТИ</button>
                
                <div class="mt-3 text-center small">
                    <a asp-area="Identity" asp-page="/Account/Register">Нет аккаунта? Регистрация</a>
                </div>
            </form>
        </div>
    </div>
</div>