@model IEnumerable<MusicStore.Models.Product>
@{ ViewData["Title"] = "Каталог"; }

<h1 class="mb-4">Каталог инструментов</h1>

<div class="row">
   <aside class="col-md-3">
    <div class="card shadow-sm p-3 mb-4 sticky-top" style="top: 20px;">
        <h5 class="mb-3">Фильтры</h5>
        <div id="filter-container">
            @foreach (var categoryName in Model.Select(p => p.Category?.Name).Distinct().Where(n => n != null))
            {
                <div class="form-check">
                    <input class="form-check-input filter-check" type="checkbox" value="@categoryName" checked>
                    <label class="form-check-label">@categoryName</label>
                </div>
            }
        </div>
        <button class="btn btn-warning btn-sm w-100 mt-3" onclick="filterProducts()">Применить</button>
    </div>
</aside>

    <div class="col-md-9">
        <div class="row row-cols-1 row-cols-md-3 g-4" id="products-grid">
            @foreach (var item in Model)
            {
                <div class="col product-item" data-category="@item.Category?.Name">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@item.ImageUrl" class="card-img-top p-2" style="height:180px; object-fit:contain;">
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title text-truncate">@item.Name</h6>
                            <p class="text-muted small">@item.Category?.Name (@item.StockQuantity шт.)</p>
                            <h5 class="text-danger fw-bold mt-auto">@item.Price.ToString("N0") ₽</h5>
                            <button class="btn btn-primary btn-sm buy-btn" 
                                    data-name="@item.Name" 
                                    data-price="@item.Price">В корзину</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>