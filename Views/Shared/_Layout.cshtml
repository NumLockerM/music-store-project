<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SoundWave - Магазин инструментов</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">SOUNDWAVE 🎸</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link text-white" href="/">Главная</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Home/Catalog">Каталог</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/Home/Contacts">Контакты</a></li>
                        <li class="nav-item"><a class="nav-link text-warning fw-bold" href="/Admin">Админка</a></li>
                    </ul>
                    <div class="navbar-nav align-items-center">
                        <a class="nav-link d-flex align-items-center me-3" href="/Cart">
                            <span class="me-1">🛒</span> Корзина
                            <span class="badge rounded-pill bg-danger ms-1" id="cart-badge">0</span>
                        </a>
                        @await Html.PartialAsync("_LoginPartial")
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4 flex-grow-1">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white-50 py-4 border-top border-secondary">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 - SoundWave Music Store - БГУ Иркутск</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
</body>
</html>