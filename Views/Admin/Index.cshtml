@model IEnumerable<MusicStore.Models.Product>
@{ ViewData["Title"] = "Админка"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Управление складом</h1>
    <a href="/Admin/Create" class="btn btn-success">➕ Добавить товар</a>
</div>

<div class="card shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>Склад</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Name</strong></td>
                    <td><span class="badge bg-info text-dark">@item.Category?.Name</span></td>
                    <td>@item.Price.ToString("N0") ₽</td>
                    <td>@item.StockQuantity шт.</td>
                    <td>
                        <div class="d-flex gap-2">
                            <a href="/Admin/Edit/@item.Id" class="btn btn-sm btn-primary">✏️ Изменить</a>
                            
                            <form action="/Admin/Delete" method="post" onsubmit="return confirm('Удалить?')">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">🗑 Удалить</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>